# ============================================================
# Breathe ESG - Environment Variables Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Django secret key (generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=your-secret-key-here

# Set to True for local development, False for production
DEBUG=True

# Comma-separated list of allowed hosts (e.g. localhost,127.0.0.1,yourdomain.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- PostgreSQL Database ----
DB_NAME=breathe_esg
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ---- CORS ----
# Comma-separated list of origins allowed to make cross-site requests
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Django settings module ----
# Use breathe_esg.settings.development for local dev
# Use breathe_esg.settings.production for production
DJANGO_SETTINGS_MODULE=breathe_esg.settings.development
